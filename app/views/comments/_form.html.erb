<%= turbo_frame_tag "post_comment_form" do %>
  <%= form_with(model: [@topic, @post, comment]) do |form| %>
      <% render "comments/shared/error_messages", resource: form.object %>

      <div class="field mb-4 container mx-auto">
        <%= form.label :Content %>
        <%= form.rich_text_area :body, class: "border border-[#2a2a2a] rounded-md outline-none" %>
      </div>

      
    <div class="actions bg-[#ed5024] hover:bg-[#e0603c] pb-1 pr-8 pl-8 inline-block font-medium rounded-full shadow transition duration-200">
      <%= form.submit "Comment", class: "btn btn-primary", data: { turbo_frame: '_top' } %>
    </div>
    <% end %>
 <% end %>
