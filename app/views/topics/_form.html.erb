<%= form_with(model: topic, local: true) do |form| %>
    <% if topic.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(topic.errors.count, "error") %> prohibited this topic from being saved:</h2>
        <ul>
          <% topic.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  
   <div class="my-5">
      <%= form.text_field :title,
            required: true,
             class: "w-full px-3 py-2 text-white border border-[#2a2a2a] rounded-md outline-none", 
      placeholder: "Enter a title for your topic" %>
  </div>

  <!-- Tags field -->
<div class="field mb-4 text-white container mx-auto">
  <%= form.label :tag_list, "Tags", class: "text-xl font-bold text-white block pb-2 pt-5 pl-2" %>
  <%= form.text_field :tag_list, 
        class: "w-full px-3 py-2 text-white border border-[#2a2a2a] rounded-md outline-none" %>
  <p class="text-gray-400 text-sm pl-2 pt-1">Separate tags with commas ,</p>
</div>



  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
