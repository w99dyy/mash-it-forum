<% content_for :title, "All Topics" %>

<div class="posts-page px-3">
  <!-- Page Header -->

  <div class="mb-2 border-b border-[#2a2a2a] pb-8">
    <h1 class="text-2xl font-bold text-white mb-4"> Topics </h1>
    <p class="text-gray-400 text-sm "> Browse all posts </p>
    <p class="float-right text-gray-400">Comments</p>
    <p class="text-gray-400 float-right pr-7"> Posts </p>
  </div>

  <!-- Topics List -->
  
  <div class="posts-container divide-y divide-[#2a2a2a]">
  
  <% @topics.each do |topic| %>
    <div class="topic mt-4">

    <div class="float-right text-gray-400">
    <div class="flex items-center gap-22 pr-7">
      <span><%= topic.posts.count %> </span>
      <span><%= topic.posts.sum { |post| post.comments.count } %></span>
    </div>
    </div>
      <h2><%= link_to topic.title, topic_posts_path(topic), class: "hover:text-[#ababab] transition font-bold" %></h2>
      <p><%= topic.content %></p>
      <!-- Tags -->

    <% if topic.tags.any? %>
      <div class="tags mb-4 mt-2">
        <div class="flex flex-wrap gap-2">
          <% topic.tags.each do |tag| %>
           <%= link_to tag.name, topics_path(tag: tag.name),
          class: "bg-[#de7200] text-white px-4 rounded-full text-sm hover:bg-[#df8322]" %>

          <% end %>
        </div>
      </div>
    <% end %>
    
    </div>

  <% end %>
      
  </div>
</div>