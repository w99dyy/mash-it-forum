<% content_for :title, "All Topics" %>

<div class="posts-page px-3">
  <!-- Page Header -->

  <div class="mb-2">
    <h1 class="text-2xl font-bold text-white mb-4"><%= t :Topics %></h1>
    <p class="text-gray-400 text-sm border-b border-[#2a2a2a] pb-4"><%= t :Browse_all_posts %></p>
  </div>

  <!-- Posts List -->
  
  <div class="posts-container divide-y divide-[#2a2a2a]">
  
  <% @topics.each do |topic| %>
    <div class="topic">
      <h2><%= link_to topic.title, topic_posts_path(topic) %></h2>
      <p><%= topic.content %></p>
      <small>By <%= topic.user.username if topic.user %></small>
      <small><%= topic.posts.count %> posts</small>

      <!-- Tags -->

    <% if topic.tags.any? %>
      <div class="tags mb-4">
        <div class="flex flex-wrap gap-2">
          <% topic.tags.each do |tag| %>
           <%= link_to tag.name, topics_path(tag: tag.name),
          class: "bg-blue-700 text-white px-4 rounded-full text-sm hover:bg-blue-600" %>

          <% end %>
        </div>
      </div>
    <% end %>
    
    </div>

  <% end %>
      
  </div>
</div>